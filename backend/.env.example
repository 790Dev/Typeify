# --- Core ---
PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/typeify

# --- Authentication (JWT) ---
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=10d

# --- Email Services (Nodemailer/Brevo) ---
BREVO_SMTP_HOST=smtp.gmail.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_email@gmail.com
BREVO_SMTP_PASS=your_app_password

# --- AI Coaching (Groq) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Multiplayer (Redis) ---
REDIS_URI=rediss://default:your_redis_token@your_redis_url:6379
